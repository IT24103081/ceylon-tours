RewriteEngine On

# Canonical home URL: always use "/"
RewriteRule ^index(?:\.html)?/?$ / [R=301,L,NC]

# Redirect explicit .html URLs to clean extensionless URLs.
# Example: /tours.html -> /tours
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Serve extensionless URLs from matching .html files.
# Example: /tours -> /tours.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
